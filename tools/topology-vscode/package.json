{
  "name": "topology-vscode",
  "displayName": "Topology Editor",
  "description": "Drag-and-drop editor for topology.json (wirefold)",
  "version": "0.0.1",
  "publisher": "dtauraso",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "topology.editor",
        "displayName": "Topology Editor",
        "selector": [
          {
            "filenamePattern": "**/*topology.json"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "package": "vsce package"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "lit-html": "^3.3.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reactflow": "^11.11.4"
  }
}
